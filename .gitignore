# Git Ignore File
# 无人机飞行申请系统 - Git忽略配置

# ============================================
# Python / FastAPI (uav-server)
# ============================================
# 虚拟环境
uav-server/venv/
uav-server/env/
uav-server/.env
uav-server/.venv

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 分发/打包
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 测试
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 日志
*.log
logs/

# 本地配置
uav-server/.env.local
uav-server/.env.development
uav-server/.env.production

# ============================================
# Node.js / Vue (uav-h5)
# ============================================
# 依赖
uav-h5/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# 构建输出
uav-h5/dist/
uav-h5/dist-ssr/
uav-h5/*.local

# 编辑器
uav-h5/.idea/
uav-h5/.vscode/
uav-h5/*.suo
uav-h5/*.ntvs*
uav-h5/*.njsproj
uav-h5/*.sln
uav-h5/*.sw?

# 测试
uav-h5/coverage/

# ============================================
# 数据库
# ============================================
*.db
*.sqlite
*.sqlite3
mongodb/
data/

# ============================================
# 系统文件
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# 临时文件
# ============================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# ============================================
# 密钥和敏感信息
# ============================================
*.pem
*.key
secrets.json
credentials.json
